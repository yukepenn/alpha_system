# Track curated placeholders before later forbidden globs override payloads.
!**/.gitkeep
!**/README.md

# Python and local tooling
.venv/
venv/
node_modules/
__pycache__/
**/__pycache__/
.pytest_cache/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
*.pyc

# Claude Code harness local runtime lock (the /loop scheduler).
.claude/scheduled_tasks.lock

# Logs, temp files, and caches
**/*.log
**/logs/
**/tmp/
**/temp/
**/cache/

# Local environment files and credentials
**/.env
**/.env.*
**/*.key
**/*.pem
**/secret.*
**/secrets.*
**/*_secret.*
**/*-secret.*
**/credential
**/credential/**
**/credentials
**/credentials/**
**/credential.*
**/credentials.*
**/*_credential.*
**/*-credential.*
**/*_credentials.*
**/*-credentials.*
**/token.*
**/tokens.*
**/*_token.*
**/*-token.*
**/*_tokens.*
**/*-tokens.*
**/private_key.*
**/private-key.*
**/*_private_key.*
**/*-private-key.*

# Local data and model artifacts
**/*.dbn
**/*.dbn.*
**/*.raw
**/*.zst
**/*.zstd
**/*.parquet
**/*.arrow
**/*.feather
**/*.pkl
**/*.pickle
**/*.joblib
**/*.onnx
**/*.npy
**/*.npz
**/*.pt
**/*.pth

# Local database files
**/*.sqlite
**/*.sqlite3
**/*.db
**/*.db-journal
**/*.wal
metadata/*.sqlite
metadata/*.sqlite3
metadata/*.db
metadata/*.db-journal
metadata/*.wal

# Local-only data directories: keep placeholders only.
data/raw/**
!data/raw/
!data/raw/.gitkeep
!data/raw/README.md

data/canonical/**
!data/canonical/
!data/canonical/.gitkeep
!data/canonical/README.md

data/factors/**
!data/factors/
!data/factors/.gitkeep
!data/factors/README.md

data/labels/**
!data/labels/
!data/labels/.gitkeep
!data/labels/README.md

data/cache/**
!data/cache/
!data/cache/.gitkeep
!data/cache/README.md

# Databento local-only payload directories.
databento/**
data/databento/**
data/raw/databento/**
data/canonical/databento/**

# Local metadata directory: keep placeholders only.
metadata/**
!metadata/
!metadata/.gitkeep
!metadata/README.md

# Generated artifacts: keep placeholders only.
artifacts/**
!artifacts/
!artifacts/**/
!artifacts/README.md
!artifacts/.gitkeep
!artifacts/**/README.md
!artifacts/**/.gitkeep

# Frontier Workflow 2 runtime state is always local-only.
runs/**

# Editable-install build metadata (local only)
*.egg-info/
**/*.egg-info/

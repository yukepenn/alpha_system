{
  "schema": "alpha_system.futures_substrate_scaleout.feature_scaleout_config.v1",
  "campaign_id": "ALPHA_FUTURES_RESEARCH_SUBSTRATE_SCALEOUT_V1",
  "phase_id": "FUTSUB-P08",
  "phase_source": "FUTSUB-P05",
  "family": "vwap_session_auction",
  "governed_scope": [
    "running_vwap",
    "anchored_eth_vwap",
    "distance_to_vwap",
    "opening_range",
    "overnight_range",
    "rth_open_context"
  ],
  "feature_bindings": {
    "running_vwap": {
      "governed_ohlcv_feature": "vwap",
      "window": "running_session_expanding",
      "uses_final_session_aggregate": false
    },
    "anchored_eth_vwap": {
      "governed_ohlcv_feature": "anchored_vwap",
      "anchor_session_label": "ETH",
      "window": "running_anchor_expanding",
      "uses_final_session_aggregate": false
    },
    "distance_to_vwap": {
      "governed_ohlcv_feature": "distance_to_vwap",
      "window": "derived_from_running_vwap",
      "uses_final_session_aggregate": false
    },
    "opening_range": {
      "governed_ohlcv_feature": "opening_range",
      "opening_range_minutes": 30,
      "uses_final_session_aggregate": false
    },
    "overnight_range": {
      "governed_ohlcv_feature": "overnight_range",
      "window": "eth_range_freezes_after_eth_segment",
      "uses_final_session_aggregate": false
    },
    "rth_open_context": {
      "governed_ohlcv_feature": "session_minute",
      "context": "session-relative RTH open position from current row timestamps",
      "uses_final_session_aggregate": false
    }
  },
  "anchor_definitions": {
    "running_vwap": {
      "anchor": "current session",
      "reset": "session_label change",
      "availability": "current row available_ts"
    },
    "anchored_eth_vwap": {
      "anchor": "ETH session start",
      "reset": "next ETH session start",
      "availability": "current row available_ts"
    }
  },
  "leakage_policy": {
    "running_point_in_time_only": true,
    "forbidden_intraday_inputs": [
      "final_session_vwap",
      "full_session_value_area",
      "closing_auction_print"
    ]
  },
  "batch_unit_grid": {
    "unit_grain": [
      "family",
      "symbol",
      "year"
    ],
    "symbols": [
      "ES",
      "NQ",
      "RTY"
    ],
    "years": [
      2018,
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "input_schemas": [
      "ohlcv_1m"
    ],
    "dense_grid_required": false
  },
  "budgets": {
    "row_budget_per_unit": 550000,
    "parquet_file_budget_per_unit": 1,
    "batch_unit_count": 27,
    "aggregate_row_budget": 14850000,
    "aggregate_parquet_file_budget": 27
  },
  "dataset_selection": {
    "inventory_ref": "configs/features/scaleout/dataset_version_inventory.json",
    "required_schemas": [
      "ohlcv_1m"
    ],
    "eligible_states": [
      "ACCEPTED",
      "ACCEPTED_WITH_WARNINGS"
    ],
    "fail_closed_on_blocked_or_missing_lock": true
  },
  "value_store": {
    "format": "parquet",
    "jsonl_research_scale_allowed": false,
    "value_namespace": "features/materialized/futures_substrate_scaleout_v1/vwap_session_auction"
  },
  "checkpoint": {
    "checkpoint_root": "materialization/futures_substrate_scaleout_v1/checkpoints/features/vwap_session_auction",
    "completed_manifest": "materialization/futures_substrate_scaleout_v1/checkpoints/features/vwap_session_auction/completed_units.jsonl",
    "completion_marker_template": "materialization/futures_substrate_scaleout_v1/checkpoints/features/vwap_session_auction/units/{unit_id}.json"
  },
  "resource_guard": {
    "resource_class": "materialization_registry",
    "parallel_safe": false,
    "registry": "registry/features.sqlite"
  },
  "identity": {
    "unit_id_formula": "mbu_<sha256(canonical_json(schema,campaign_id,family,symbol,year,input_schemas,dataset_version_id,value_store_format))>",
    "partition_template": "{symbol}.{year}.full_year",
    "dry_run_preview_ref": "research/futures_substrate_scaleout_v1/materialization/batch_plan.md#dry-run-identity-preview"
  }
}

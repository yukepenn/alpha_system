{
  "schema": "alpha_system.futures_substrate_scaleout.feature_scaleout_config.v1",
  "campaign_id": "ALPHA_FUTURES_RESEARCH_SUBSTRATE_SCALEOUT_V1",
  "phase_id": "FUTSUB-P13",
  "phase_source": "FUTSUB-P05",
  "family": "cross_market_alignment",
  "governed_scope": [
    "aligned_returns",
    "beta_residual",
    "basket_residual",
    "relative_strength_rank",
    "catch_up_rotation",
    "divergence_agreement",
    "lead_lag"
  ],
  "batch_unit_grid": {
    "unit_grain": [
      "family",
      "target_symbol",
      "year"
    ],
    "symbols": [
      "ES",
      "NQ",
      "RTY"
    ],
    "cross_market_inputs": [
      "ES",
      "NQ",
      "RTY"
    ],
    "years": [
      2018,
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "input_schemas": [
      "ohlcv_1m",
      "ohlcv_dense_research_grid"
    ],
    "dense_grid_required": true
  },
  "budgets": {
    "row_budget_per_unit": 550000,
    "input_row_budget_per_unit": 1650000,
    "parquet_file_budget_per_unit": 1,
    "batch_unit_count": 27,
    "aggregate_row_budget": 14850000,
    "aggregate_input_row_budget": 44550000,
    "aggregate_parquet_file_budget": 27
  },
  "dataset_selection": {
    "inventory_ref": "configs/features/scaleout/dataset_version_inventory.json",
    "required_schemas": [
      "ohlcv_1m",
      "ohlcv_dense_research_grid"
    ],
    "eligible_states": [
      "ACCEPTED",
      "ACCEPTED_WITH_WARNINGS"
    ],
    "fail_closed_on_blocked_or_missing_lock": true
  },
  "value_store": {
    "format": "parquet",
    "jsonl_research_scale_allowed": false,
    "value_namespace": "features/materialized/futures_substrate_scaleout_v1/cross_market_alignment"
  },
  "checkpoint": {
    "checkpoint_root": "materialization/futures_substrate_scaleout_v1/checkpoints/features/cross_market_alignment",
    "completed_manifest": "materialization/futures_substrate_scaleout_v1/checkpoints/features/cross_market_alignment/completed_units.jsonl",
    "completion_marker_template": "materialization/futures_substrate_scaleout_v1/checkpoints/features/cross_market_alignment/units/{unit_id}.json"
  },
  "resource_guard": {
    "resource_class": "materialization_registry",
    "parallel_safe": false,
    "registry": "registry/features.sqlite"
  },
  "identity": {
    "unit_id_formula": "mbu_<sha256(canonical_json(schema,campaign_id,family,target_symbol,year,input_schemas,dataset_version_ids,value_store_format))>",
    "partition_template": "{target_symbol}.{year}.full_year",
    "dry_run_preview_ref": "research/futures_substrate_scaleout_v1/materialization/batch_plan.md#dry-run-identity-preview"
  },
  "alignment_policy": {
    "per_instrument_available_ts_required": true,
    "strict_event_intersection_required": true,
    "cross_instrument_forward_fill_forbidden": true,
    "missing_instrument_imputation_forbidden": true,
    "output_available_ts_rule": "latest_contributing_per_instrument_available_ts_for_same_event_ts",
    "binding_policy": "config labels bind to existing governed cross-market primitives only"
  }
}

{
  "schema": "alpha_system.futures_substrate_scaleout.feature_scaleout_config.v1",
  "campaign_id": "ALPHA_FUTURES_RESEARCH_SUBSTRATE_SCALEOUT_V1",
  "phase_id": "P113000_RESTORE_EXEC_CONFIGS",
  "phase_source": "FUTSUB-P07",
  "family": "session_calendar_maintenance",
  "governed_scope": [
    "session_id",
    "minutes_from_rth_open",
    "minutes_to_rth_close",
    "rth_segment_flag",
    "eth_segment_flag",
    "day_of_week",
    "minutes_to_expiration",
    "halt_status_flag"
  ],
  "targeting": {
    "feature_groups": {
      "identity_migration_replacements": [
        "day_of_week",
        "minutes_to_expiration",
        "halt_status_flag"
      ],
      "full_post_deprecation": [
        "session_id",
        "minutes_from_rth_open",
        "minutes_to_rth_close",
        "rth_segment_flag",
        "eth_segment_flag",
        "day_of_week",
        "minutes_to_expiration",
        "halt_status_flag"
      ]
    }
  },
  "batch_unit_grid": {
    "unit_grain": [
      "family",
      "symbol",
      "year"
    ],
    "symbols": [
      "ES",
      "NQ",
      "RTY"
    ],
    "years": [
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "input_schemas": [
      "ohlcv_1m",
      "ohlcv_dense_research_grid"
    ],
    "dense_grid_required": true
  },
  "budgets": {
    "row_budget_per_unit": 550000,
    "parquet_file_budget_per_unit": 1,
    "batch_unit_count": 24,
    "aggregate_row_budget": 13200000,
    "aggregate_parquet_file_budget": 24
  },
  "dataset_selection": {
    "inventory_ref": "configs/features/scaleout/dataset_version_inventory.json",
    "required_schemas": [
      "ohlcv_1m",
      "ohlcv_dense_research_grid"
    ],
    "eligible_states": [
      "ACCEPTED",
      "ACCEPTED_WITH_WARNINGS"
    ],
    "fail_closed_on_blocked_or_missing_lock": true
  },
  "value_store": {
    "format": "parquet",
    "jsonl_research_scale_allowed": false,
    "value_namespace": "features/materialized/futures_substrate_scaleout_v1/session_calendar_maintenance"
  },
  "checkpoint": {
    "checkpoint_root": "materialization/futures_substrate_scaleout_v1/checkpoints/features/pack_restore/session_calendar_maintenance",
    "completed_manifest": "materialization/futures_substrate_scaleout_v1/checkpoints/features/pack_restore/session_calendar_maintenance/completed_units.jsonl",
    "completion_marker_template": "materialization/futures_substrate_scaleout_v1/checkpoints/features/pack_restore/session_calendar_maintenance/units/{unit_id}.json"
  },
  "resource_guard": {
    "resource_class": "materialization_registry",
    "parallel_safe": false,
    "registry": "registry/features.sqlite"
  },
  "identity": {
    "unit_id_formula": "mbu_<sha256(canonical_json(schema,campaign_id,family,symbol,year,input_schemas,dataset_version_ids,value_store_format))>",
    "partition_template": "{symbol}_{year}_full_year",
    "dry_run_preview_ref": "P113000_RESTORE_EXEC_CONFIGS"
  },
  "point_in_time_guard": {
    "metadata_role": "SESSION_METADATA_POINT_IN_TIME",
    "metadata_available_ts_required_when_metadata_is_row_specific": true,
    "fail_closed_if_metadata_available_ts_exceeds_row_available_ts": true
  }
}

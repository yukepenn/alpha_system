    "max_gross_exposure": "1.00",
    "max_net_exposure": "0.50"
  },
  "multi_symbol_constraints": {
    "required_identifier": "instrument_id",
    "max_active_instruments": 20,
    "allow_repeated_instrument_targets": false
  },
  "future_sector_asset_constraints": {
    "mode": "contract_only",
    "enabled": false,
    "rules": []
  },
  "future_correlation_aware_allocation": {
    "mode": "contract_only",
    "enabled": false,
    "inputs": []
  },
  "signal_to_target_conversion": {
    "mode": "entry_exit_to_target",
    "use_desired_exposure": true,
    "use_confidence": false,
    "exit_signal_target_percent": "0"
  }
}

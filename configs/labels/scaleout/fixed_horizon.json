{
  "schema": "alpha_system.futures_substrate_scaleout.label_scaleout_config.v1",
  "campaign_id": "ALPHA_FUTURES_RESEARCH_SUBSTRATE_SCALEOUT_V1",
  "phase_id": "FUTSUB-P16",
  "phase_source": "FUTSUB-P05",
  "family": "fixed_horizon",
  "governed_scope": [
    "fwd_ret_1m",
    "fwd_ret_3m",
    "fwd_ret_5m",
    "fwd_ret_10m",
    "fwd_ret_15m",
    "fwd_ret_30m"
  ],
  "targeting": {
    "label_groups": {
      "diagnostic": [
        "fwd_ret_1m",
        "fwd_ret_3m"
      ],
      "primary": [
        "fwd_ret_5m",
        "fwd_ret_10m",
        "fwd_ret_15m",
        "fwd_ret_30m"
      ],
      "all": [
        "fwd_ret_1m",
        "fwd_ret_3m",
        "fwd_ret_5m",
        "fwd_ret_10m",
        "fwd_ret_15m",
        "fwd_ret_30m"
      ]
    },
    "estimated_seconds_per_unit": 90
  },
  "batch_unit_grid": {
    "unit_grain": [
      "family",
      "symbol",
      "year",
      "horizon"
    ],
    "symbols": [
      "ES",
      "NQ",
      "RTY"
    ],
    "years": [
      2018,
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "horizons": [
      "1m",
      "3m",
      "5m",
      "10m",
      "15m",
      "30m"
    ],
    "input_schemas": [
      "ohlcv_1m"
    ]
  },
  "budgets": {
    "row_budget_per_unit": 550000,
    "parquet_file_budget_per_unit": 1,
    "batch_unit_count": 162,
    "aggregate_row_budget": 89100000,
    "aggregate_parquet_file_budget": 162
  },
  "dataset_selection": {
    "inventory_ref": "configs/labels/scaleout/dataset_version_inventory.json",
    "required_schemas": [
      "ohlcv_1m"
    ],
    "eligible_states": [
      "ACCEPTED",
      "ACCEPTED_WITH_WARNINGS"
    ],
    "fail_closed_on_blocked_or_missing_lock": true
  },
  "guards": {
    "label_available_ts_required": true,
    "roll_splice_guard_required": true,
    "maintenance_crossing_guard_required": true,
    "roll_policy_ref": "docs/futures_substrate_scaleout/ROLL_GUARD.md",
    "roll_cross_policy": "drop",
    "roll_policy_id": "roll_cme_index_futures_quarterly",
    "roll_guard_version": "roll_guard_v1",
    "roll_window": {
      "days_before": 2,
      "days_after": 1
    },
    "maintenance_crossing_policy": "drop",
    "maintenance_policy_id": "cme_index_futures_daily_maintenance_break_v1",
    "maintenance_guard_version": "maintenance_crossing_guard_v1",
    "terminal_key": "series_id+contract_id+event_ts"
  },
  "value_store": {
    "format": "parquet",
    "jsonl_research_scale_allowed": false,
    "value_namespace": "labels/materialized/futures_substrate_scaleout_v1/fixed_horizon"
  },
  "checkpoint": {
    "checkpoint_root": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/fixed_horizon",
    "completed_manifest": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/fixed_horizon/completed_units.jsonl",
    "completion_marker_template": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/fixed_horizon/units/{unit_id}.json"
  },
  "resource_guard": {
    "resource_class": "materialization_registry",
    "parallel_safe": false,
    "registry": "registry/labels.sqlite"
  },
  "identity": {
    "unit_id_formula": "mbu_<sha256(canonical_json(schema,campaign_id,family,symbol,year,horizon,dataset_version_id,value_store_format))>",
    "partition_template": "{symbol}.{year}.{horizon}",
    "dry_run_preview_ref": "research/futures_substrate_scaleout_v1/materialization/batch_plan.md#dry-run-identity-preview"
  }
}

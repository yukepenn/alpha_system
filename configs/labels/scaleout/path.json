{
  "schema": "alpha_system.futures_substrate_scaleout.label_scaleout_config.v1",
  "campaign_id": "ALPHA_FUTURES_RESEARCH_SUBSTRATE_SCALEOUT_V1",
  "phase_id": "FUTSUB-P20",
  "phase_source": "FUTSUB-P05",
  "family": "path",
  "governed_scope": [
    "mfe",
    "mae",
    "target_before_stop",
    "triple_barrier"
  ],
  "batch_unit_grid": {
    "unit_grain": [
      "family",
      "symbol",
      "year",
      "horizon"
    ],
    "symbols": [
      "ES",
      "NQ",
      "RTY"
    ],
    "years": [
      2018,
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "horizons": [
      "5m",
      "10m",
      "15m",
      "30m",
      "60m",
      "120m",
      "240m"
    ],
    "input_schemas": [
      "ohlcv_1m"
    ],
    "metrics_per_unit": [
      "mfe",
      "mae",
      "target_before_stop",
      "triple_barrier"
    ]
  },
  "budgets": {
    "row_budget_per_unit": 550000,
    "path_metric_evaluation_budget_per_unit": 2200000,
    "parquet_file_budget_per_unit": 1,
    "batch_unit_count": 189,
    "aggregate_row_budget": 103950000,
    "aggregate_path_metric_evaluation_budget": 415800000,
    "aggregate_parquet_file_budget": 189
  },
  "dataset_selection": {
    "inventory_ref": "configs/labels/scaleout/dataset_version_inventory.json",
    "required_schemas": [
      "ohlcv_1m"
    ],
    "eligible_states": [
      "ACCEPTED",
      "ACCEPTED_WITH_WARNINGS"
    ],
    "fail_closed_on_blocked_or_missing_lock": true
  },
  "guards": {
    "label_available_ts_required": true,
    "label_available_ts_rules": {
      "mfe": "window_end_available_ts",
      "mae": "window_end_available_ts",
      "target_before_stop": "first_barrier_touch_available_ts_or_window_end_available_ts",
      "triple_barrier": "first_barrier_touch_available_ts_or_window_end_available_ts"
    },
    "roll_splice_guard_required": true,
    "maintenance_crossing_guard_required": true,
    "overlap_aware_n_eff_metadata_required": true,
    "terminal_key": "series_id+contract_id+event_ts",
    "terminal_resolution": "full_path_window_guarded_before_scan",
    "roll_policy_ref": "docs/futures_substrate_scaleout/ROLL_GUARD.md",
    "expensive_or_unstable_cases_must_be_flagged": true
  },
  "engine": {
    "selected": "v1",
    "selection_basis": "LCFP-P08 accepted path labels on the V1 fast label producer path.",
    "cli": "--engine v1 --workers 8",
    "env": {
      "ALPHA_LABEL_CPU_WORKERS": "8",
      "POLARS_MAX_THREADS": "2",
      "OMP_NUM_THREADS": "2",
      "RAYON_NUM_THREADS": "2",
      "NUMBA_NUM_THREADS": "2"
    },
    "registry_writes": "parent_only_serial",
    "reference_oracle": "alpha_system.labels.families.path"
  },
  "path_label_definitions": {
    "parameter_source": "existing governed path-family definitions plus FUTSUB-P05 batch plan; no parameter sweep or tuning",
    "price_field": "close",
    "direction": "long",
    "target_return": 0.02,
    "stop_return": -0.02,
    "same_bar_policy": "ambiguous",
    "variants": {
      "mfe": {
        "definition": "maximum favorable excursion over the guarded forward real-trade-bar window",
        "label_available_ts": "window end / effective guarded terminal availability"
      },
      "mae": {
        "definition": "maximum adverse excursion over the guarded forward real-trade-bar window",
        "label_available_ts": "window end / effective guarded terminal availability"
      },
      "target_before_stop": {
        "definition": "boolean target-before-stop path outcome using governed target_return and stop_return",
        "label_available_ts": "first target/stop touch availability; if no touch, guarded window end availability"
      },
      "triple_barrier": {
        "definition": "upper/lower/time barrier outcome encoded as target=1, stop=-1, horizon=0, ambiguous=null",
        "label_available_ts": "first target/stop touch availability; if no touch, guarded window end availability"
      }
    }
  },
  "feasibility_policy": {
    "risk_id": "R-021",
    "where_feasible": true,
    "per_unit_budget": {
      "row_budget": 550000,
      "path_metric_evaluation_budget": 2200000,
      "measured_bound_required_for_infeasible_units": true
    },
    "silent_skip_allowed": false,
    "unbounded_compute_allowed": false
  },
  "value_store": {
    "format": "parquet",
    "jsonl_research_scale_allowed": false,
    "value_namespace": "labels/materialized/futures_substrate_scaleout_v1/path"
  },
  "checkpoint": {
    "checkpoint_root": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/path",
    "completed_manifest": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/path/completed_units.jsonl",
    "completion_marker_template": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/path/units/{unit_id}.json"
  },
  "resource_guard": {
    "resource_class": "materialization_registry",
    "parallel_safe": false,
    "registry": "registry/labels.sqlite"
  },
  "identity": {
    "unit_id_formula": "mbu_<sha256(canonical_json(schema,campaign_id,family,symbol,year,horizon,metrics,dataset_version_id,value_store_format))>",
    "partition_template": "{symbol}.{year}.{horizon}",
    "dry_run_preview_ref": "research/futures_substrate_scaleout_v1/materialization/batch_plan.md#dry-run-identity-preview"
  }
}

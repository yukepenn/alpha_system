  "campaign_id": "ALPHA_FUTURES_RESEARCH_SUBSTRATE_SCALEOUT_V1",
  "phase_id": "FUTSUB-P19",
  "phase_source": "FUTSUB-P05",
  "family": "cost_adjusted",
  "governed_scope": [
    "mid_to_mid",
    "spread_crossing_adjusted",
    "fee_adjusted_where_cost_model_exists",
    "slippage_stress_adjusted_where_supported"
  ],
  "batch_unit_grid": {
    "unit_grain": [
      "family",
      "symbol",
      "year",
      "horizon"
    ],
    "symbols": [
      "ES",
      "NQ",
      "RTY"
    ],
    "years": [
      2018,
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "horizons": [
      "1m",
      "3m",
      "5m",
      "10m",
      "15m",
      "30m",
      "60m",
      "120m",
      "240m"
    ],
    "input_schemas": [
      "ohlcv_1m",
      "bbo_1m"
    ]
  },
  "budgets": {
    "row_budget_per_unit": 550000,
    "input_row_budget_per_unit": 1100000,
    "parquet_file_budget_per_unit": 1,
    "batch_unit_count": 243,
    "aggregate_row_budget": 133650000,
    "aggregate_input_row_budget": 267300000,
    "aggregate_parquet_file_budget": 243
  },
  "dataset_selection": {
    "inventory_ref": "configs/labels/scaleout/dataset_version_inventory.json",
    "required_schemas": [
      "ohlcv_1m",
      "bbo_1m"
    ],
    "eligible_states": [
      "ACCEPTED",
      "ACCEPTED_WITH_WARNINGS"
    ],
    "fail_closed_on_blocked_or_missing_lock": true
  },
  "guards": {
    "label_available_ts_required": true,
    "roll_splice_guard_required": true,
    "maintenance_crossing_guard_required": true,
    "overlap_aware_n_eff_metadata_required": true,
    "roll_policy_ref": "docs/futures_substrate_scaleout/ROLL_GUARD.md",
    "bbo_is_tradability_proxy_not_execution_truth": true
  },
  "cost_model": {
    "config_refs": [
      "configs/execution/cost_models/default_conservative.json",
      "configs/execution/cost_models/spread_sensitive_conservative.json"
    ],
    "stale_fee_or_slippage_assumptions_forbidden": true
  },
  "value_store": {
    "format": "parquet",
    "jsonl_research_scale_allowed": false,
    "value_namespace": "labels/materialized/futures_substrate_scaleout_v1/cost_adjusted"
  },
  "checkpoint": {
    "checkpoint_root": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/cost_adjusted",
    "completed_manifest": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/cost_adjusted/completed_units.jsonl",
    "completion_marker_template": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/cost_adjusted/units/{unit_id}.json"
  },
  "resource_guard": {
    "resource_class": "materialization_registry",
    "parallel_safe": false,
    "registry": "registry/labels.sqlite"
  },
  "identity": {
    "unit_id_formula": "mbu_<sha256(canonical_json(schema,campaign_id,family,symbol,year,horizon,dataset_version_ids,value_store_format,cost_model_refs))>",
    "partition_template": "{symbol}.{year}.{horizon}",
    "dry_run_preview_ref": "research/futures_substrate_scaleout_v1/materialization/batch_plan.md#dry-run-identity-preview"
  }

{
  "schema": "alpha_system.futures_substrate_scaleout.label_scaleout_config.v1",
  "campaign_id": "ALPHA_FUTURES_RESEARCH_SUBSTRATE_SCALEOUT_V1",
  "phase_id": "FUTSUB-P18",
  "phase_source": "FUTSUB-P05",
  "family": "session_close_maintenance_flat",
  "underlying_label_families": [
    "fixed_horizon",
    "event"
  ],
  "governed_scope": [
    "session_close",
    "maintenance_flat"
  ],
  "batch_unit_grid": {
    "unit_grain": [
      "family",
      "symbol",
      "year",
      "event_horizon"
    ],
    "symbols": [
      "ES",
      "NQ",
      "RTY"
    ],
    "years": [
      2018,
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "event_horizons": [
      "session_close",
      "maintenance_flat"
    ],
    "input_schemas": [
      "ohlcv_1m",
      "ohlcv_dense_research_grid"
    ]
  },
  "budgets": {
    "row_budget_per_unit": 550000,
    "parquet_file_budget_per_unit": 1,
    "batch_unit_count": 54,
    "aggregate_row_budget": 29700000,
    "aggregate_parquet_file_budget": 54
  },
  "dataset_selection": {
    "inventory_ref": "configs/labels/scaleout/dataset_version_inventory.json",
    "required_schemas": [
      "ohlcv_1m",
      "ohlcv_dense_research_grid"
    ],
    "eligible_states": [
      "ACCEPTED",
      "ACCEPTED_WITH_WARNINGS"
    ],
    "fail_closed_on_blocked_or_missing_lock": true
  },
  "guards": {
    "label_available_ts_required": true,
    "roll_splice_guard_required": true,
    "maintenance_crossing_guard_required": true,
    "roll_policy_ref": "docs/futures_substrate_scaleout/ROLL_GUARD.md",
    "maintenance_crossing_policy": "close_or_flat_before_break_only"
  },
  "value_store": {
    "format": "parquet",
    "jsonl_research_scale_allowed": false,
    "value_namespace": "labels/materialized/futures_substrate_scaleout_v1/session_close_maintenance_flat"
  },
  "checkpoint": {
    "checkpoint_root": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/session_close_maintenance_flat",
    "completed_manifest": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/session_close_maintenance_flat/completed_units.jsonl",
    "completion_marker_template": "materialization/futures_substrate_scaleout_v1/checkpoints/labels/session_close_maintenance_flat/units/{unit_id}.json"
  },
  "resource_guard": {
    "resource_class": "materialization_registry",
    "parallel_safe": false,
    "registry": "registry/labels.sqlite"
  },
  "identity": {
    "unit_id_formula": "mbu_<sha256(canonical_json(schema,campaign_id,family,symbol,year,event_horizon,dataset_version_ids,value_store_format))>",
    "partition_template": "{symbol}.{year}.{event_horizon}",
    "dry_run_preview_ref": "research/futures_substrate_scaleout_v1/materialization/batch_plan.md#dry-run-identity-preview"
  }
}
